{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["lib/**"]
    },
    "format": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "cache": false
    },
    "watch": {
      "cache": false,
      "persistent": true
    }
  }
}